# ─────────────────────────────────────────────
# LLM API（擇一或全部設定）
# 預設用 Gemini（便宜快），LLM_PROVIDER=claude 可切換
# ─────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini（推薦）
# 取得：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude（備援 / 想要更好繁中翻譯時）
# 取得：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Telegram Bot
# 1. 找 @BotFather 跑 /newbot 取得 token
# 2. 跟 bot 講一句話，跑 dropbox_auth.py 邏輯類似的腳本拿 chat_id
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Dropbox API（伺服器端必要；Mac 桌面版用戶可省略）
# 取得：https://www.dropbox.com/developers/apps
# 1. Create app → Scoped access → Full Dropbox
# 2. Permissions：勾 files.content.write/read、files.metadata.write
# 3. 跑 python3 dropbox_auth.py 完成 OAuth，refresh token 會自動寫入此檔
# ─────────────────────────────────────────────
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# 可選：自訂 Kobo 同步資料夾本地路徑（預設 ~/Dropbox/應用程式/Rakuten Kobo）
# DROPBOX_KOBO_LOCAL_PATH=/path/to/your/kobo/sync/folder

# 可選：自訂 Kobo 雲端資料夾（預設 /應用程式/Rakuten Kobo）
# DROPBOX_KOBO_REMOTE_DIR=/Apps/Rakuten Kobo
